#!/usr/bin/env bash
set -e

VERSION="1.1.1"
CONFIG_DIR="$HOME/.config/termux-connecting"
CONFIG_FILE="$CONFIG_DIR/config"
SSH_PORT=8022
SSH_KEY="$HOME/.ssh/id_ed25519"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; NC='\033[0m'
info()  { echo -e "${GREEN}[✓]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; }
title() { echo -e "\n${CYAN}━━━ $1 ━━━${NC}\n"; }

prompt() {
    local val default="$2"
    echo -n "$1${default:+ [$default]}: "
    read -r val
    echo "${val:-$default}"
}

load_config() {
    [ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"
}

save_config() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" << EOF
HOST_ALIAS="$HOST_ALIAS"
SSH_USER="$SSH_USER"
SSH_HOST="$SSH_HOST"
SSH_PORT=$SSH_PORT
TELEGRAM_BOT_TOKEN="$TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="$TELEGRAM_CHAT_ID"
EOF
    chmod 600 "$CONFIG_FILE"
}

telegram_alert() {
    local msg="$1"
    if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_CHAT_ID" ]; then
        curl -s --connect-timeout 10 --max-time 15 \
            "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
            -d "chat_id=${TELEGRAM_CHAT_ID}" \
            -d "text=${msg}" >/dev/null
    fi
}

# ─── COMMAND: connection ──────────────────────────────────────
cmd_connection() {
    load_config
    title "TERMUX CONNECT — Connection Setup"

    local first_run=false
    if [ ! -f "$CONFIG_FILE" ]; then
        first_run=true
        echo "Pertama kali dijalankan. Setup koneksi ke Termux."
        echo "------------------------------------------------"
    fi

    HOST_ALIAS=$(prompt "Nama alias" "${HOST_ALIAS:-termux-a8star}")
    SSH_USER=$(prompt "Username" "${SSH_USER:-u0_a237}")
    SSH_HOST=$(prompt "IP Address" "${SSH_HOST:-192.168.1.8}")

    title "1. Cek Konektifitas"
    echo "Mencoba ke ${SSH_USER}@${SSH_HOST}:${SSH_PORT}..."

    local connected=false
    if timeout 10 ssh -o ConnectTimeout=5 -o BatchMode=yes -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" "echo connected"; then
        info "Koneksi berhasil (key-based)"
        connected=true
    elif command -v sshpass; then
        local pass
        pass=$(prompt "Password SSH" "")
        if timeout 10 sshpass -p "$pass" ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" "echo connected"; then
            info "Koneksi berhasil (password)"
            connected=true
        fi
    else
        echo ""
        warn "sshpass tidak terinstall. Konek manual dulu: ssh -p ${SSH_PORT} ${SSH_USER}@${SSH_HOST}"
        echo -n "  Setelah berhasil, tekan enter untuk lanjut..."; read -r
        if timeout 10 ssh -o ConnectTimeout=5 -o BatchMode=yes -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" "echo connected"; then
            connected=true
        fi
    fi

    if ! $connected; then
        error "Tidak bisa terhubung ke ${SSH_USER}@${SSH_HOST}:${SSH_PORT}"
        echo "  Pastikan sshd sudah jalan di Termux dan satu jaringan."
        return 1
    fi

    # SSH key
    if [ ! -f "$SSH_KEY" ]; then
        echo ""
        echo -n "Buat SSH key biar tanpa password? [Y/n]: "
        read -r mk
        if [[ -z "$mk" || "$mk" =~ ^[Yy]$ ]]; then
            ssh-keygen -t ed25519 -f "$SSH_KEY" -N "" -C "termux-connect"
        fi
    fi
    if [ -f "$SSH_KEY" ]; then
        timeout 15 ssh-copy-id -o StrictHostKeyChecking=no -o ConnectTimeout=10 -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" 2>&1 || \
            warn "Copy key gagal. Manual: ssh-copy-id -p ${SSH_PORT} ${SSH_USER}@${SSH_HOST}"
    fi

    # SSH config
    mkdir -p "$HOME/.ssh"
    if ! grep -q "Host $HOST_ALIAS$" "$HOME/.ssh/config" 2>/dev/null; then
        cat >> "$HOME/.ssh/config" << EOF

Host $HOST_ALIAS
    HostName $SSH_HOST
    User $SSH_USER
    Port $SSH_PORT
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
EOF
        chmod 600 "$HOME/.ssh/config"
    fi
    info "Koneksi siap: ssh $HOST_ALIAS"

    # Telegram — hanya first run
    if $first_run; then
        title "2. Telegram Alert (opsional)"
        echo "Ingin dapat notifikasi Telegram saat koneksi bermasalah?"
        echo -n "Setup sekarang? [y/N]: "; read -r tk
        if [[ "$tk" =~ ^[Yy]$ ]]; then
            TELEGRAM_BOT_TOKEN=$(prompt "Bot Token (dari @BotFather)" "")
            TELEGRAM_CHAT_ID=$(prompt "Chat ID (atau username @username)" "")
            if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_CHAT_ID" ]; then
                telegram_alert "✅ *termux-connect-pc* — Admin tersimpan"
                info "Telegram alert aktif"
            else
                warn "Lewati Telegram. Bisa diatur nanti dengan edit: $CONFIG_FILE"
            fi
        else
            info "Telegram bisa diaktifkan nanti: $CONFIG_FILE"
        fi
    fi

    save_config
    echo ""
    info "Setup selesai! Jalankan: termux-connect-pc check"
}

# ─── COMMAND: check ───────────────────────────────────────────
cmd_check() {
    load_config
    if [ ! -f "$CONFIG_FILE" ]; then
        warn "Belum ada konfigurasi. Jalankan dulu: termux-connect-pc connection"
        return 1
    fi

    title "TERMUX CONNECT — Check"
    echo "Memeriksa ${HOST_ALIAS} (${SSH_USER}@${SSH_HOST}:${SSH_PORT})..."
    echo ""

    local ok=false
    if timeout 10 ssh -o ConnectTimeout=5 -o BatchMode=yes "$HOST_ALIAS" "echo connected"; then
        info "Koneksi OK"
        ok=true
    else
        error "Koneksi GAGAL"
        telegram_alert "🚨 *Koneksi Termux PUTUS*%0AHost: ${HOST_ALIAS}%0AUser: ${SSH_USER}%0AIP: ${SSH_HOST}:${SSH_PORT}%0AWaktu: $(date)"
        echo ""
        warn "Notifikasi sudah dikirim ke Telegram admin"
        echo ""
        echo -n "Coba lagi? [y/N]: "; read -r retry
        if [[ "$retry" =~ ^[Yy]$ ]]; then
            cmd_check
            return
        fi
    fi

    if $ok; then
        echo ""
        info "Gunakan ssh $HOST_ALIAS untuk koneksi"
        echo ""
        echo -n "Cek lagi nanti secara berkala? (setup cron/dimonitor) [y/N]: "; read -r monitor
        if [[ "$monitor" =~ ^[Yy]$ ]]; then
            echo ""
            echo "  Tambahkan ke crontab (crontab -e):"
            echo "  */5 * * * * ${0} check"
        fi
    fi
}

# ─── COMMAND: help ────────────────────────────────────────────
cmd_help() {
    echo ""
    echo "termux-connect-pc v${VERSION}"
    echo "CLI koneksi Termux dari PC/Mac"
    echo ""
    echo "Penggunaan:"
    echo "  termux-connect-pc connection    Setup koneksi ke Termux (hanya sekali)"
    echo "  termux-connect-pc check         Cek status koneksi & kirim alert"
    echo "  termux-connect-pc help          Tampilkan bantuan ini"
    echo "  termux-connect-pc version       Tampilkan versi"
    echo ""
    echo "Telegram alert otomatis ke admin saat koneksi putus."
    echo ""
}

# ─── COMMAND: version ─────────────────────────────────────────
cmd_version() {
    echo "termux-connect-pc v${VERSION}"
}

# ─── MAIN ─────────────────────────────────────────────────────
main() {
    case "${1:-}" in
        connection) cmd_connection ;;
        check)      cmd_check ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) cmd_version ;;
        *)
            if [ ! -f "$CONFIG_FILE" ]; then
                echo "Pertama kali dijalankan! Setup koneksi dulu."
                echo ""
                cmd_connection
            else
                cmd_help
            fi
            ;;
    esac
}

main "$@"
