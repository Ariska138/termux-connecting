#!/usr/bin/env bash

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${GREEN}[✓]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; }
title() { echo -e "\n${CYAN}━━━ $1 ━━━${NC}\n"; }

SSH_PORT=8022
SSH_CONFIG="$HOME/.ssh/config"
SSH_KEY="$HOME/.ssh/id_ed25519"

get_input() {
    local prompt="$1" default="$2" val
    if [ -n "$default" ]; then
        echo -n "$prompt [$default]: "
    else
        echo -n "$prompt: "
    fi
    read -r val
    echo "${val:-$default}"
}

detect_ssh_hosts() {
    if [ ! -f "$SSH_CONFIG" ]; then
        return
    fi
    while IFS= read -r line; do
        if [[ "$line" =~ ^Host[[:space:]]+([^* ]+) ]]; then
            echo "${BASH_REMATCH[1]}"
        fi
    done < "$SSH_CONFIG"
}

setup_cloudflare_tunnel() {
    local host_alias="$1" username="$2" ip="$3"
    local cloudflared_bin="cloudflared"
    local tunnel_dir="$HOME/.cloudflared"

    if ! command -v "$cloudflared_bin"; then
        warn "cloudflared belum terinstall."
        echo ""
        echo "  Install dulu:"
        echo "  Mac : brew install cloudflared"
        echo "  Linux: curl -L https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 -o /usr/local/bin/cloudflared && chmod +x /usr/local/bin/cloudflared"
        echo ""
        echo -n "  Install cloudflared sekarang? [y/N]: "
        read -r install_cf
        if [[ "$install_cf" =~ ^[Yy]$ ]]; then
            if [[ "$(uname)" == "Darwin" ]]; then
                if command -v brew; then
                    brew install cloudflared && info "cloudflared terinstall"
                else
                    error "Homebrew tidak ditemukan. Install manual."
                    return
                fi
            elif [[ "$(uname)" == "Linux" ]]; then
                curl -L --connect-timeout 15 --max-time 60 https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 -o /usr/local/bin/cloudflared && chmod +x /usr/local/bin/cloudflared && info "cloudflared terinstall"
            else
                error "OS tidak dikenal. Install manual."
                return
            fi
        else
            return
        fi
    fi

    if [ ! -f "$tunnel_dir/cert.pem" ]; then
        echo ""
        warn "Belum login ke Cloudflare."
        echo ""
        echo "  Dibutuhkan:"
        echo "  1. Buka https://dash.cloudflare.com/profile/api-tokens"
        echo "  2. Buat token dengan permission: Cloudflare Tunnel -> Edit"
        echo "  3. Masukkan token di bawah"
        echo ""
        local token
        token=$(get_input "Cloudflare API Token" "")
        if [ -n "$token" ]; then
            mkdir -p "$tunnel_dir"
            echo "$token" > "$tunnel_dir/api-token"
            chmod 600 "$tunnel_dir/api-token"
            info "Token disimpan di $tunnel_dir/api-token"
            echo ""
            info "Jalankan login manual:"
            echo "  cloudflared tunnel login"
            echo ""
            warn "Pastikan di Cloudflare Dashboard:"
            echo "  - Zero Trust -> Access -> Tunnels sudah diaktifkan"
            echo "  - DNS route sudah diatur (misal: ssh.domain.com)"
            echo ""
            echo -n "  Lanjutkan? [y/N]: "
            read -r proceed
            if [[ "$proceed" =~ ^[Yy]$ ]]; then
                echo ""
                echo "  Langkah setup tunnel:"
                echo "  1. cloudflared tunnel login"
                echo "  2. cloudflared tunnel create termux-tunnel"
                echo "  3. cloudflared tunnel route dns termux-tunnel ssh.domain.com"
                echo "  4. cloudflared tunnel run termux-tunnel"
                echo ""
                info "Setelah tunnel jalan, konek dari luar:"
                echo "  ssh -o ProxyCommand='cloudflared access ssh --hostname ssh.domain.com' ${host_alias}"
            fi
        else
            warn "Token tidak dimasukkan. Lewati setup tunnel."
        fi
    else
        info "Cloudflare sudah terkonfigurasi di $tunnel_dir"
        echo ""
        echo "  Cek tunnel: cloudflared tunnel list"
        echo "  Jalankan: cloudflared tunnel run <nama-tunnel>"
    fi
}

main() {
    title "TERMUX CONNECT — PC"
    echo "Menyiapkan koneksi ke Termux dari PC/Mac"
    echo "----------------------------------------"

    # ─── Step 1: Cari host yang sudah dikenal ───
    local known_hosts=()
    while IFS= read -r h; do
        known_hosts+=("$h")
    done < <(detect_ssh_hosts)

    local select_host="" select_user="" select_ip=""

    if [ ${#known_hosts[@]} -gt 0 ]; then
        echo "Host SSH yang ditemukan di ~/.ssh/config:"
        local i=1
        for h in "${known_hosts[@]}"; do
            echo "  $i) $h"
            ((i++))
        done
        echo "  $i) (Masukkan manual)"
        echo ""
        echo -n "Pilih host [1-$i]: "
        read -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -lt "$i" ]; then
            select_host="${known_hosts[$((choice-1))]}"
            info "Menggunakan host: $select_host"
            if timeout 10 ssh -o ConnectTimeout=5 -o BatchMode=yes "$select_host" "echo connected"; then
                info "Koneksi SSH berhasil dengan host $select_host"
                echo ""
                echo -n "Ingin setup tunnel Cloudflare? [y/N]: "
                read -r setup_tunnel
                if [[ "$setup_tunnel" =~ ^[Yy]$ ]]; then
                    setup_cloudflare_tunnel "$select_host" "" ""
                fi
                return
            else
                warn "Host $select_host tidak bisa dijangkau, lanjut setup manual..."
            fi
        fi
    fi

    # ─── Step 2: Input manual ───
    echo "Masukkan informasi perangkat Termux:"
    local username ip password
    username=$(get_input "Username" "u0_a237")
    ip=$(get_input "IP Address" "192.168.1.8")
    password=$(get_input "Password (ssh)")

    # ─── Step 3: Cek konektifitas ───
    title "1. Cek Konektifitas"
    echo "Mencoba koneksi ke ${username}@${ip}:${SSH_PORT}..."

    local connected=false
    if timeout 10 ssh -o ConnectTimeout=5 -o BatchMode=yes -p "$SSH_PORT" "${username}@${ip}" "echo connected"; then
        info "Koneksi SSH berhasil (key-based)"
        connected=true
    elif command -v sshpass; then
        if sshpass -p "$password" ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 -p "$SSH_PORT" "${username}@${ip}" "echo connected"; then
            info "Koneksi SSH berhasil (password)"
            connected=true
        fi
    fi

    if ! $connected; then
        error "Tidak bisa terhubung ke ${username}@${ip}:${SSH_PORT}"
        echo ""
        echo "  Pastikan:"
        echo "  - HP sudah menjalankan: sshd (di Termux)"
        echo "  - HP dan PC dalam jaringan WiFi yang SAMA"
        echo "  - IP yang dimasukkan benar"
        echo ""
        echo "  Cek IP di Termux: ip a | grep inet"
        if ! command -v sshpass; then
            echo ""
            warn "Install sshpass untuk koneksi otomatis pakai password:"
            echo "  Mac : brew install hudochenkov/sshpass/sshpass"
            echo "  Linux: apt install sshpass"
        fi
        return 1
    fi

    # ─── Step 4: Setup SSH key ───
    title "2. Setup SSH Key"
    if [ -f "$SSH_KEY" ]; then
        info "SSH key sudah ada: $SSH_KEY"
    else
        echo -n "Buat SSH key untuk koneksi tanpa password? [Y/n]: "
        read -r make_key
        if [[ -z "$make_key" || "$make_key" =~ ^[Yy]$ ]]; then
            ssh-keygen -t ed25519 -f "$SSH_KEY" -N "" -C "termux-connect"
            info "SSH key dibuat: $SSH_KEY.pub"
        fi
    fi

    if [ -f "$SSH_KEY" ]; then
        echo "Mencoba copy public key ke perangkat..."
        if timeout 15 ssh-copy-id -o StrictHostKeyChecking=no -o ConnectTimeout=10 -p "$SSH_PORT" "${username}@${ip}"; then
            info "SSH key berhasil di-copy. Koneksi tanpa password siap!"
            if timeout 10 ssh -o ConnectTimeout=5 -o BatchMode=yes -p "$SSH_PORT" "${username}@${ip}" "echo connected"; then
                info "Verifikasi key-based login: berhasil"
            fi
        else
            warn "Gagal copy otomatis. Copy manual:"
            echo "  ssh-copy-id -p ${SSH_PORT} ${username}@${ip}"
        fi
    fi

    # ─── Step 5: Setup SSH config ───
    title "3. Setup SSH Config"
    local host_alias
    host_alias=$(get_input "Nama alias untuk koneksi ini" "termux-a8star")
    mkdir -p "$HOME/.ssh"
    if ! grep -q "Host $host_alias$" "$SSH_CONFIG"; then
        cat >> "$SSH_CONFIG" << EOF

Host $host_alias
    HostName $ip
    User $username
    Port $SSH_PORT
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
EOF
        chmod 600 "$SSH_CONFIG"
        info "SSH config dibuat. Koneksi via: ssh $host_alias"
    else
        info "Host '$host_alias' sudah ada di SSH config"
    fi

    # ─── Step 6: Cloudflare Tunnel ───
    title "4. Cloudflare Tunnel (Koneksi Online)"
    echo -n "Ingin setup tunnel agar bisa koneksi dari luar jaringan? [y/N]: "
    read -r setup_tunnel
    if [[ "$setup_tunnel" =~ ^[Yy]$ ]]; then
        setup_cloudflare_tunnel "$host_alias" "$username" "$ip"
    fi

    echo ""
    echo "----------------------------------------"
    info "Setup selesai!"
    echo ""
    echo "  Local : ssh $host_alias"
    echo "  atau  : ssh -p ${SSH_PORT} ${username}@${ip}"
}

main "$@"
