#!/usr/bin/env bash
set -e

VERSION="1.1.12"
CONFIG_DIR="$HOME/.config/termux-connecting"
CONFIG_FILE="$CONFIG_DIR/config"
DEVICES_DIR="$CONFIG_DIR/devices"
ACTIVE_DEVICE=""
SSH_PORT=8022
SSH_KEY="$HOME/.ssh/id_ed25519"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; NC='\033[0m'
info()  { echo -e "${GREEN}[✓]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; }
title() { echo -e "\n${CYAN}━━━ $1 ━━━${NC}\n"; }

prompt() {
    local val default="$2"
    echo -n "$1${default:+ [$default]}: " >&2
    read -r val
    echo "${val:-$default}"
}

has_timeout() {
    command -v timeout >/dev/null 2>&1 || command -v gtimeout >/dev/null 2>&1
}

run_timeout() {
    local sec="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$sec" "$@"
    elif command -v gtimeout >/dev/null 2>&1; then
        gtimeout "$sec" "$@"
    else
        "$@"
    fi
}

load_active() {
    if [ -f "$CONFIG_FILE" ]; then
        ACTIVE_DEVICE=$(cat "$CONFIG_FILE")
    fi
}

load_config() {
    local name="${1:-$ACTIVE_DEVICE}"
    [ -z "$name" ] && return 1
    local file="$DEVICES_DIR/$name"
    [ -f "$file" ] && source "$file" || return 1
}

save_config() {
    local name="${1:-$ACTIVE_DEVICE}"
    [ -z "$name" ] && return 1
    mkdir -p "$DEVICES_DIR"
    cat > "$DEVICES_DIR/$name" << EOF
HOST_ALIAS="$name"
SSH_USER="$SSH_USER"
SSH_HOST="$SSH_HOST"
SSH_PORT=$SSH_PORT
TELEGRAM_BOT_TOKEN="$TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="$TELEGRAM_CHAT_ID"
EOF
    chmod 600 "$DEVICES_DIR/$name"
}

set_active() {
    local name="$1"
    mkdir -p "$CONFIG_DIR"
    echo "$name" > "$CONFIG_FILE"
    ACTIVE_DEVICE="$name"
}

list_devices() {
    mkdir -p "$DEVICES_DIR"
    for f in "$DEVICES_DIR"/*; do
        [ -f "$f" ] && basename "$f"
    done
}

telegram_alert() {
    local msg="$1"
    if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_CHAT_ID" ]; then
        curl -s --connect-timeout 10 --max-time 15 \
            "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
            -d "chat_id=${TELEGRAM_CHAT_ID}" \
            -d "text=${msg}" >/dev/null
    fi
}

# ─── COMMAND: connection ──────────────────────────────────────
cmd_connection() {
    local new_name="${1:-}"
    load_active

    if [ -n "$new_name" ]; then
        HOST_ALIAS="$new_name"
    fi

    title "TERMUX CONNECT — Connection Setup"
    echo "Saya akan bantu kamu menghubungkan PC ini ke Termux di HP."
    echo ""

    # ── Dialog: device baru atau edit existing ──
    if [ -z "$new_name" ] && [ -n "$ACTIVE_DEVICE" ]; then
        echo "  Saat ini device aktif: $ACTIVE_DEVICE"
        echo -n "  ➤  Setup device baru? [y/N]: "
        read -r new_dev
        if [[ "$new_dev" =~ ^[Yy]$ ]]; then
            echo ""
            echo "  Oke, kita akan setup HP lain."
            new_name=$(prompt "  ➤  Beri nama device ini" "")
            HOST_ALIAS="$new_name"
        else
            load_config || true
            HOST_ALIAS="${ACTIVE_DEVICE}"
        fi
    fi

    # ── Dialog: nama device ──
    if [ -z "$HOST_ALIAS" ]; then
        echo ""
        echo "  Beri nama untuk HP ini, misal 'hp-kantor' atau 'hp-rumah'."
        HOST_ALIAS=$(prompt "  ➤  Nama device" "termux-a8star")
    fi

    # ── Dialog: username ──
    echo ""
    echo "  Sekarang kita perlu data login SSH."
    echo "  Username bisa dicek di Termux dengan perintah: whoami"
    SSH_USER=$(prompt "  ➤  Username" "${SSH_USER:-u0_a237}")

    # ── Dialog: IP address ──
    echo ""
    echo "  IP Address bisa dicek di Termux dengan: ip a | grep inet"
    echo "  Pastikan HP dan PC terhubung ke WiFi yang SAMA."
    SSH_HOST=$(prompt "  ➤  IP Address" "${SSH_HOST:-192.168.1.8}")

    # ── Dialog: Port ──
    echo ""
    echo -n "  ➤  Port SSH [8022]: "; read -r port
    SSH_PORT="${port:-8022}"

    # ── Konfirmasi ──
    echo ""
    echo "  ┌──────────────────────────────────────┐"
    echo "  │  Device : $HOST_ALIAS"
    echo "  │  Login  : ${SSH_USER}@${SSH_HOST}:${SSH_PORT}"
    echo "  └──────────────────────────────────────┘"
    echo ""
    echo -n "  ➤  Lanjutkan koneksi? [Y/n]: "
    read -r proceed
    if [[ -n "$proceed" && ! "$proceed" =~ ^[Yy]$ ]]; then
        echo "  Baik, batalkan. Jalankan lagi saat siap."
        return
    fi

    # ── Cek Konektifitas ──
    title "1. Cek Konektifitas"
    echo "  Mencoba koneksi ke ${SSH_USER}@${SSH_HOST}:${SSH_PORT}..."
    echo ""

    local connected=false

    # Key-based
    if run_timeout 10 ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=5 -o BatchMode=yes -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" "echo connected"; then
        info "Koneksi berhasil (key-based)"
        connected=true
    # Password via sshpass
    elif command -v sshpass >/dev/null; then
        echo "  SSH key tidak dikenali. Coba dengan password..."
        local pass
        pass=$(prompt "  ➤  Password SSH" "")
        if run_timeout 10 sshpass -p "$pass" ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" "echo connected"; then
            info "Koneksi berhasil (password)"
            connected=true
        fi
    # Manual
    else
        echo ""
        warn "  sshpass tidak terinstall."
        echo "  Silakan konek manual dari terminal lain:"
        echo "  ssh -p ${SSH_PORT} ${SSH_USER}@${SSH_HOST}"
        echo ""
        echo -n "  ➤  Setelah berhasil, tekan enter untuk lanjut..."; read -r
        if run_timeout 10 ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=5 -o BatchMode=yes -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" "echo connected"; then
            connected=true
        fi
    fi

    # ── Gagal total ──
    if ! $connected; then
        error "Gagal terhubung ke ${SSH_USER}@${SSH_HOST}:${SSH_PORT}"
        echo ""
        echo "  Pastikan:"
        echo "  1. HP sudah menjalankan: sshd (di Termux)"
        echo "  2. HP dan PC dalam jaringan WiFi yang SAMA"
        echo "  3. IP dan username yang dimasukkan benar"
        echo ""
        echo "  Coba lagi: termux-connect-pc connection"
        return
    fi

    # ── Setup SSH key ──
    title "2. Setup SSH Key (biar tanpa password)"
    echo "  Dengan SSH key, kamu tidak perlu input password setiap kali konek."
    echo ""

    if [ ! -f "$SSH_KEY" ]; then
        echo -n "  ➤  Buat SSH key sekarang? [Y/n]: "
        read -r mk
        if [[ -z "$mk" || "$mk" =~ ^[Yy]$ ]]; then
            echo "  Membuat SSH key..."
            ssh-keygen -t ed25519 -f "$SSH_KEY" -N "" -C "termux-connect"
            info "SSH key dibuat: $SSH_KEY"
        fi
    else
        info "SSH key sudah ada: $SSH_KEY"
    fi

    if [ -f "$SSH_KEY" ]; then
        echo ""
        echo "  Meng-copy public key ke HP..."
        local copy_ok=false
        if command -v sshpass >/dev/null && [ -n "$pass" ]; then
            if run_timeout 15 sshpass -p "$pass" ssh-copy-id -i "$SSH_KEY" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}"; then
                copy_ok=true
            fi
        else
            if run_timeout 15 ssh-copy-id -i "$SSH_KEY" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}"; then
                copy_ok=true
            fi
        fi
        if $copy_ok; then
            info "Public key berhasil di-copy ke HP"
        else
            warn "Gagal copy otomatis. Copy manual:"
            echo "  ssh-copy-id -i ${SSH_KEY} -p ${SSH_PORT} ${SSH_USER}@${SSH_HOST}"
        fi
    fi

    # ── Setup SSH config ──
    title "3. Setup SSH Config"
    echo "  Membuat alias '${HOST_ALIAS}' di ~/.ssh/config"
    echo "  Nanti cukup: ssh ${HOST_ALIAS}"
    echo ""
    mkdir -p "$HOME/.ssh"
    if ! grep -q "Host $HOST_ALIAS$" "$HOME/.ssh/config"; then
        cat >> "$HOME/.ssh/config" << EOF

Host $HOST_ALIAS
    HostName $SSH_HOST
    User $SSH_USER
    Port $SSH_PORT
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
EOF
        chmod 600 "$HOME/.ssh/config"
        info "SSH config siap: ssh $HOST_ALIAS"
    else
        info "Host '$HOST_ALIAS' sudah ada di SSH config"
    fi

    # ── Telegram ──
    title "4. Telegram Alert (opsional)"
    echo "  Dapat notifikasi saat koneksi ke HP ini putus."
    echo ""
    echo -n "  ➤  Setup Telegram? [y/N]: "
    read -r tk
    local tel_setup=false
    if [[ "$tk" =~ ^[Yy]$ ]]; then
        echo ""
        echo "  Butuh Bot Token dari @BotFather dan Chat ID kamu."
        TELEGRAM_BOT_TOKEN=$(prompt "  ➤  Bot Token" "")
        TELEGRAM_CHAT_ID=$(prompt "  ➤  Chat ID (atau @username)" "")
        if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_CHAT_ID" ]; then
            tel_setup=true
        else
            warn "Data tidak lengkap. Telegram bisa diatur nanti."
        fi
    fi

    # ── Simpan ──
    save_config "$HOST_ALIAS"
    set_active "$HOST_ALIAS"

    if $tel_setup; then
        telegram_alert "✅ *termux-connect-pc* — Device ${HOST_ALIAS} siap"
        info "Telegram alert aktif ✅"
    fi

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    info "Setup selesai!"
    echo ""
    echo "  Koneksi: ssh ${HOST_ALIAS}"
    echo "  Cek     : termux-connect-pc check"
    echo "  Device lain: termux-connect-pc connection <nama>"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
}

# ─── COMMAND: list ────────────────────────────────────────────
cmd_list() {
    load_active
    title "TERMUX CONNECT — Devices"
    local devices=()
    while IFS= read -r d; do
        devices+=("$d")
    done < <(list_devices)

    if [ ${#devices[@]} -eq 0 ]; then
        warn "Belum ada device. Tambah: termux-connect-pc connection"
        return
    fi

    for d in "${devices[@]}"; do
        if [ "$d" = "$ACTIVE_DEVICE" ]; then
            echo -e "  ${GREEN}→ $d (aktif)${NC}"
            # tampilkan detail
            SSH_USER=""; SSH_HOST=""
            source "$DEVICES_DIR/$d" || true
            [ -n "$SSH_HOST" ] && echo "     $SSH_USER@$SSH_HOST:$SSH_PORT"
            [ -n "$TELEGRAM_BOT_TOKEN" ] && echo "     Telegram: aktif"
        else
            echo "    $d"
        fi
    done
    echo ""
    echo "  Gunakan: termux-connect-pc switch <nama>"
}

# ─── COMMAND: switch ──────────────────────────────────────────
cmd_switch() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Nama device diperlukan. Lihat: termux-connect-pc list"
        return
    fi
    if [ ! -f "$DEVICES_DIR/$name" ]; then
        error "Device '$name' tidak ditemukan"
        return
    fi
    set_active "$name"
    info "Beralih ke device: $name"
}

# ─── COMMAND: check ───────────────────────────────────────────
cmd_check() {
    load_active
    if [ -z "$ACTIVE_DEVICE" ] || ! load_config; then
        warn "Belum ada device. Tambah: termux-connect-pc connection"
        return
    fi

    title "TERMUX CONNECT — Check"
    echo "Device: ${ACTIVE_DEVICE} (${SSH_USER}@${SSH_HOST}:${SSH_PORT})"
    echo ""

    if run_timeout 10 ssh -o ConnectTimeout=5 -o BatchMode=yes "$ACTIVE_DEVICE" "echo connected"; then
        info "Koneksi OK"
        echo ""
        info "Gunakan ssh $ACTIVE_DEVICE untuk koneksi"
    else
        error "Koneksi GAGAL"
        telegram_alert "🚨 *Koneksi Termux PUTUS*%0ADevice: ${ACTIVE_DEVICE}%0AHost: ${SSH_USER}@${SSH_HOST}:${SSH_PORT}%0AWaktu: $(date)"
        echo ""
        warn "Notifikasi sudah dikirim ke Telegram admin"
        echo ""
        echo -n "Coba lagi? [y/N]: "
        read -r retry
        if [[ "$retry" =~ ^[Yy]$ ]]; then
            cmd_check
            return
        fi
    fi
}

# ─── COMMAND: remove ──────────────────────────────────────────
cmd_remove() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Nama device diperlukan"
        return
    fi
    if [ ! -f "$DEVICES_DIR/$name" ]; then
        error "Device '$name' tidak ditemukan"
        return
    fi
    rm "$DEVICES_DIR/$name"
    info "Device '$name' dihapus"
    # Hapus dari SSH config
    if [ -f "$HOME/.ssh/config" ]; then
        sed -i '' "/^Host $name\$/,/^$/d" "$HOME/.ssh/config" || true
    fi
    if [ "$ACTIVE_DEVICE" = "$name" ]; then
        rm -f "$CONFIG_FILE"
        ACTIVE_DEVICE=""
        warn "Device aktif dihapus. Set active: termux-connect-pc switch <nama>"
    fi
}

# ─── COMMAND: help ────────────────────────────────────────────
cmd_help() {
    echo ""
    echo "termux-connect-pc v${VERSION}"
    echo "CLI koneksi Termux dari PC/Mac"
    echo ""
    echo "Penggunaan:"
    echo "  termux-connect-pc connection [nama]  Setup device baru"
    echo "  termux-connect-pc list               Daftar semua device"
    echo "  termux-connect-pc switch <nama>      Pilih device aktif"
    echo "  termux-connect-pc check              Cek koneksi device aktif"
    echo "  termux-connect-pc remove <nama>      Hapus device"
    echo "  termux-connect-pc help               Bantuan ini"
    echo "  termux-connect-pc version            Versi"
    echo ""
    echo "Multi-device: kelola beberapa HP Termux dari satu PC."
    echo "Telegram alert otomatis ke admin saat koneksi putus."
    echo ""
}

# ─── COMMAND: version ─────────────────────────────────────────
cmd_version() {
    echo "termux-connect-pc v${VERSION}"
}

# ─── MAIN ─────────────────────────────────────────────────────
main() {
    case "${1:-}" in
        connection) cmd_connection "${2:-}" ;;
        list|ls)    cmd_list ;;
        switch|use) cmd_switch "${2:-}" ;;
        check)      cmd_check ;;
        remove|rm)  cmd_remove "${2:-}" ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) cmd_version ;;
        *)
            load_active
            if [ -z "$ACTIVE_DEVICE" ]; then
                echo ""
                echo "  Ini pertama kali kamu jalankan termux-connect-pc."
                echo "  Kita akan setup koneksi ke Termux di HP kamu."
                echo ""
                cmd_connection
            else
                echo ""
                echo "  Device aktif saat ini: ${ACTIVE_DEVICE}"
                echo ""
                echo "  1) Konek ke ${ACTIVE_DEVICE}"
                echo "  2) Tambah device baru"
                echo "  3) Lihat daftar device"
                echo ""
                echo -n "  Pilih [1]: "
                read -r choice
                case "$choice" in
                    2) cmd_connection ;;
                    3) cmd_list ;;
                    *) cmd_check ;;
                esac
            fi
            ;;
    esac
}

main "$@"
