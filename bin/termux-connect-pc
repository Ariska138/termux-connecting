#!/usr/bin/env bash
set -e

VERSION="1.1.12"
CONFIG_DIR="$HOME/.config/termux-connecting"
CONFIG_FILE="$CONFIG_DIR/config"
DEVICES_DIR="$CONFIG_DIR/devices"
ACTIVE_DEVICE=""
SSH_PORT=8022
SSH_KEY="$HOME/.ssh/id_ed25519"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; NC='\033[0m'
info()  { echo -e "${GREEN}[✓]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; }
title() { echo -e "\n${CYAN}━━━ $1 ━━━${NC}\n"; }

prompt() {
    local val default="$2"
    echo -n "$1${default:+ [$default]}: "
    read -r val
    echo "${val:-$default}"
}

load_active() {
    if [ -f "$CONFIG_FILE" ]; then
        ACTIVE_DEVICE=$(cat "$CONFIG_FILE")
    fi
}

load_config() {
    local name="${1:-$ACTIVE_DEVICE}"
    [ -z "$name" ] && return 1
    local file="$DEVICES_DIR/$name"
    [ -f "$file" ] && source "$file" || return 1
}

save_config() {
    local name="${1:-$ACTIVE_DEVICE}"
    [ -z "$name" ] && return 1
    mkdir -p "$DEVICES_DIR"
    cat > "$DEVICES_DIR/$name" << EOF
HOST_ALIAS="$name"
SSH_USER="$SSH_USER"
SSH_HOST="$SSH_HOST"
SSH_PORT=$SSH_PORT
TELEGRAM_BOT_TOKEN="$TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="$TELEGRAM_CHAT_ID"
EOF
    chmod 600 "$DEVICES_DIR/$name"
}

set_active() {
    local name="$1"
    mkdir -p "$CONFIG_DIR"
    echo "$name" > "$CONFIG_FILE"
    ACTIVE_DEVICE="$name"
}

list_devices() {
    mkdir -p "$DEVICES_DIR"
    for f in "$DEVICES_DIR"/*; do
        [ -f "$f" ] && basename "$f"
    done
}

telegram_alert() {
    local msg="$1"
    if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_CHAT_ID" ]; then
        curl -s --connect-timeout 10 --max-time 15 \
            "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
            -d "chat_id=${TELEGRAM_CHAT_ID}" \
            -d "text=${msg}" >/dev/null
    fi
}

# ─── COMMAND: connection ──────────────────────────────────────
cmd_connection() {
    local new_name="${1:-}"
    load_active

    # Jika ada argumen nama, setup device baru
    if [ -n "$new_name" ]; then
        HOST_ALIAS="$new_name"
    fi

    title "TERMUX CONNECT — Connection Setup"

    if [ -z "$new_name" ] && [ -n "$ACTIVE_DEVICE" ]; then
        echo "  Device aktif: $ACTIVE_DEVICE"
        echo -n "  Setup device baru? [y/N]: "
        read -r new_dev
        if [[ "$new_dev" =~ ^[Yy]$ ]]; then
            new_name=$(prompt "Nama device baru" "")
            HOST_ALIAS="$new_name"
        else
            # Edit device aktif
            load_config || true
            HOST_ALIAS="${ACTIVE_DEVICE}"
        fi
    fi

    if [ -z "$HOST_ALIAS" ]; then
        HOST_ALIAS=$(prompt "Nama alias" "termux-a8star")
    fi

    SSH_USER=$(prompt "Username" "${SSH_USER:-u0_a237}")
    SSH_HOST=$(prompt "IP Address" "${SSH_HOST:-192.168.1.8}")

    title "1. Cek Konektifitas"
    echo "Mencoba ke ${SSH_USER}@${SSH_HOST}:${SSH_PORT}..."

    local connected=false
    if timeout 10 ssh -o ConnectTimeout=5 -o BatchMode=yes -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" "echo connected"; then
        info "Koneksi berhasil (key-based)"
        connected=true
    elif command -v sshpass >/dev/null; then
        local pass
        pass=$(prompt "Password SSH" "")
        if timeout 10 sshpass -p "$pass" ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" "echo connected"; then
            info "Koneksi berhasil (password)"
            connected=true
        fi
    else
        echo ""
        warn "sshpass tidak terinstall. Konek manual dulu: ssh -p ${SSH_PORT} ${SSH_USER}@${SSH_HOST}"
        echo -n "  Setelah berhasil, tekan enter untuk lanjut..."; read -r
        if timeout 10 ssh -o ConnectTimeout=5 -o BatchMode=yes -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" "echo connected"; then
            connected=true
        fi
    fi

    if ! $connected; then
        error "Tidak bisa terhubung ke ${SSH_USER}@${SSH_HOST}:${SSH_PORT}"
        echo "  Pastikan sshd sudah jalan di Termux dan satu jaringan."
        return
    fi

    # SSH key
    if [ ! -f "$SSH_KEY" ]; then
        echo ""
        echo -n "Buat SSH key biar tanpa password? [Y/n]: "
        read -r mk
        if [[ -z "$mk" || "$mk" =~ ^[Yy]$ ]]; then
            ssh-keygen -t ed25519 -f "$SSH_KEY" -N "" -C "termux-connect"
        fi
    fi
    if [ -f "$SSH_KEY" ]; then
        timeout 15 ssh-copy-id -o StrictHostKeyChecking=no -o ConnectTimeout=10 -p "$SSH_PORT" "${SSH_USER}@${SSH_HOST}" 2>&1 || \
            warn "Copy key gagal. Manual: ssh-copy-id -p ${SSH_PORT} ${SSH_USER}@${SSH_HOST}"
    fi

    # SSH config
    mkdir -p "$HOME/.ssh"
    if ! grep -q "Host $HOST_ALIAS$" "$HOME/.ssh/config"; then
        cat >> "$HOME/.ssh/config" << EOF

Host $HOST_ALIAS
    HostName $SSH_HOST
    User $SSH_USER
    Port $SSH_PORT
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
EOF
        chmod 600 "$HOME/.ssh/config"
    fi
    info "Koneksi siap: ssh $HOST_ALIAS"

    # Telegram — hanya first time
    local tel_setup=false
    if [ -z "$TELEGRAM_BOT_TOKEN" ]; then
        echo ""
        title "2. Telegram Alert (opsional)"
        echo -n "Ingat notifikasi Telegram saat koneksi putus? [y/N]: "
        read -r tk
        if [[ "$tk" =~ ^[Yy]$ ]]; then
            TELEGRAM_BOT_TOKEN=$(prompt "Bot Token (dari @BotFather)" "")
            TELEGRAM_CHAT_ID=$(prompt "Chat ID (atau @username)" "")
            if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_CHAT_ID" ]; then
                tel_setup=true
            else
                warn "Lewati Telegram. Bisa diatur nanti edit file device."
            fi
        fi
    fi

    # Simpan & set active
    save_config "$HOST_ALIAS"
    set_active "$HOST_ALIAS"

    if $tel_setup; then
        telegram_alert "✅ *termux-connect-pc* — Admin tersimpan"
        info "Telegram alert aktif"
    fi

    echo ""
    info "Setup selesai! Jalankan: termux-connect-pc check"
}

# ─── COMMAND: list ────────────────────────────────────────────
cmd_list() {
    load_active
    title "TERMUX CONNECT — Devices"
    local devices=()
    while IFS= read -r d; do
        devices+=("$d")
    done < <(list_devices)

    if [ ${#devices[@]} -eq 0 ]; then
        warn "Belum ada device. Tambah: termux-connect-pc connection"
        return
    fi

    for d in "${devices[@]}"; do
        if [ "$d" = "$ACTIVE_DEVICE" ]; then
            echo -e "  ${GREEN}→ $d (aktif)${NC}"
            # tampilkan detail
            SSH_USER=""; SSH_HOST=""
            source "$DEVICES_DIR/$d" || true
            [ -n "$SSH_HOST" ] && echo "     $SSH_USER@$SSH_HOST:$SSH_PORT"
            [ -n "$TELEGRAM_BOT_TOKEN" ] && echo "     Telegram: aktif"
        else
            echo "    $d"
        fi
    done
    echo ""
    echo "  Gunakan: termux-connect-pc switch <nama>"
}

# ─── COMMAND: switch ──────────────────────────────────────────
cmd_switch() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Nama device diperlukan. Lihat: termux-connect-pc list"
        return
    fi
    if [ ! -f "$DEVICES_DIR/$name" ]; then
        error "Device '$name' tidak ditemukan"
        return
    fi
    set_active "$name"
    info "Beralih ke device: $name"
}

# ─── COMMAND: check ───────────────────────────────────────────
cmd_check() {
    load_active
    if [ -z "$ACTIVE_DEVICE" ] || ! load_config; then
        warn "Belum ada device. Tambah: termux-connect-pc connection"
        return
    fi

    title "TERMUX CONNECT — Check"
    echo "Device: ${ACTIVE_DEVICE} (${SSH_USER}@${SSH_HOST}:${SSH_PORT})"
    echo ""

    if timeout 10 ssh -o ConnectTimeout=5 -o BatchMode=yes "$ACTIVE_DEVICE" "echo connected"; then
        info "Koneksi OK"
        echo ""
        info "Gunakan ssh $ACTIVE_DEVICE untuk koneksi"
    else
        error "Koneksi GAGAL"
        telegram_alert "🚨 *Koneksi Termux PUTUS*%0ADevice: ${ACTIVE_DEVICE}%0AHost: ${SSH_USER}@${SSH_HOST}:${SSH_PORT}%0AWaktu: $(date)"
        echo ""
        warn "Notifikasi sudah dikirim ke Telegram admin"
        echo ""
        echo -n "Coba lagi? [y/N]: "
        read -r retry
        if [[ "$retry" =~ ^[Yy]$ ]]; then
            cmd_check
            return
        fi
    fi
}

# ─── COMMAND: remove ──────────────────────────────────────────
cmd_remove() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Nama device diperlukan"
        return
    fi
    if [ ! -f "$DEVICES_DIR/$name" ]; then
        error "Device '$name' tidak ditemukan"
        return
    fi
    rm "$DEVICES_DIR/$name"
    info "Device '$name' dihapus"
    # Hapus dari SSH config
    if [ -f "$HOME/.ssh/config" ]; then
        sed -i '' "/^Host $name\$/,/^$/d" "$HOME/.ssh/config" || true
    fi
    if [ "$ACTIVE_DEVICE" = "$name" ]; then
        rm -f "$CONFIG_FILE"
        ACTIVE_DEVICE=""
        warn "Device aktif dihapus. Set active: termux-connect-pc switch <nama>"
    fi
}

# ─── COMMAND: help ────────────────────────────────────────────
cmd_help() {
    echo ""
    echo "termux-connect-pc v${VERSION}"
    echo "CLI koneksi Termux dari PC/Mac"
    echo ""
    echo "Penggunaan:"
    echo "  termux-connect-pc connection [nama]  Setup device baru"
    echo "  termux-connect-pc list               Daftar semua device"
    echo "  termux-connect-pc switch <nama>      Pilih device aktif"
    echo "  termux-connect-pc check              Cek koneksi device aktif"
    echo "  termux-connect-pc remove <nama>      Hapus device"
    echo "  termux-connect-pc help               Bantuan ini"
    echo "  termux-connect-pc version            Versi"
    echo ""
    echo "Multi-device: kelola beberapa HP Termux dari satu PC."
    echo "Telegram alert otomatis ke admin saat koneksi putus."
    echo ""
}

# ─── COMMAND: version ─────────────────────────────────────────
cmd_version() {
    echo "termux-connect-pc v${VERSION}"
}

# ─── MAIN ─────────────────────────────────────────────────────
main() {
    case "${1:-}" in
        connection) cmd_connection "${2:-}" ;;
        list|ls)    cmd_list ;;
        switch|use) cmd_switch "${2:-}" ;;
        check)      cmd_check ;;
        remove|rm)  cmd_remove "${2:-}" ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) cmd_version ;;
        *)
            load_active
            if [ -z "$ACTIVE_DEVICE" ]; then
                echo "Belum ada device. Setup koneksi pertama."
                echo ""
                cmd_connection
            else
                cmd_help
            fi
            ;;
    esac
}

main "$@"
