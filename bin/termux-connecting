#!/data/data/com.termux/files/usr/bin/bash
set -e

VERSION="1.1.45"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; NC='\033[0m'
info()  { echo -e "${GREEN}[✓]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; }
title() { echo -e "\n${CYAN}━━━ $1 ━━━${NC}\n"; }

AUTO=false
CHECK=false
DEBUG=false
for arg in "$@"; do
    [ "$arg" = "-y" ] && AUTO=true
    [ "$arg" = "--check" ] || [ "$arg" = "--status" ] && CHECK=true
    [ "$arg" = "--debug" ] && DEBUG=true
done

$DEBUG && set -x

# ─── Mode: Check/Status ───
if $CHECK; then
    echo ""
    title "TERMUX CONNECTING — Status v${VERSION}"
    echo "  ⏱  Uptime HP  : $(uptime -p 2>/dev/null || echo 'N/A')"
    echo ""
    echo "  🔑 SSH Server :"
    if pgrep -x sshd >/dev/null; then
        sshd_pid=$(pgrep -x sshd | head -1)
        echo "     ✅  Berjalan (PID: $sshd_pid)"
        if [ -n "$sshd_pid" ] && [ -d /proc/$sshd_pid ]; then
            echo "     ⏱  Uptime: $(ps -o etime= -p $sshd_pid 2>/dev/null | xargs)"
        fi
    else
        echo "     ❌  Tidak berjalan"
    fi
    echo ""
    echo "  🌐 Network    :"
    for iface in wlan0 eth0; do
        addr=$(timeout 2 ip -4 addr show $iface 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1)
        if [ -n "$addr" ]; then
            echo "     $iface : $addr"
        fi
    done
    if [ -z "$(timeout 2 ip -4 addr show 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | grep -v 127.0.0.1)" ]; then
        echo "     ❌  Tidak ada IP (nonaktif/data)"
    fi
    echo ""
    echo "  ☕  Wake Lock  :"
    if command -v termux-wake-lock >/dev/null; then
        echo "     ✅  Tersedia"
    else
        echo "     ❌  Tidak terinstall (termux-api)"
    fi
    echo ""
    echo "  💾 Storage    :"
    if [ -d "$HOME/storage" ]; then
        echo "     ✅  Terkonfigurasi"
    else
        echo "     ❌  Belum (termux-setup-storage)"
    fi
    echo ""
    echo "  🚀 Auto-start :"
    if [ -f "$HOME/.termux/boot/boot-sshd" ]; then
        echo "     ✅  Boot script ada"
    else
        echo "     ❌  Belum diatur"
    fi
    echo ""
    echo "  ⚡ Battery Opt :"
    echo "     Cek manual: Setelan → Aplikasi → Termux → Baterai"
    echo ""
    echo "  🖥  User      : $(whoami)"
    echo "  🔌 Port      : 8022"
    echo ""
    exit 0
fi

confirm() {
    local msg="$1" default="$2"
    $AUTO && return 0
    local dprompt="y/N"
    [ "$default" = "y" ] && dprompt="Y/n"
    echo -n "  ${msg}? [${dprompt}]: "
    read -r ans
    local ans="${ans:-$default}"
    [[ "$ans" =~ ^[Yy]$ ]] && return 0 || return 1
}

WELCOME_FILE="$HOME/.config/termux-connecting/.welcomed"
if [ ! -f "$WELCOME_FILE" ]; then
    echo ""
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}  termux-connecting berhasil diinstall!${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${CYAN}Script ini akan membantu kamu:${NC}"
    echo "  1. Update & upgrade paket Termux"
    echo "  2. Install Git & Node.js (jika perlu)"
    echo "  3. Set password untuk SSH"
    echo "  4. Tampilkan IP untuk koneksi dari PC"
    echo ""
    echo -e "${CYAN}Di PC/Mac, jalankan:${NC}"
    echo "  termux-connect-pc"
    echo ""
    echo -e "${CYAN}Subcommand PC:${NC}"
    echo "  termux-connect-pc connection    Setup/ubah koneksi"
    echo "  termux-connect-pc check         Cek koneksi & kirim alert Telegram"
    echo "  termux-connect-pc help          Bantuan"
    echo "  termux-connect-pc version       Versi"
    echo ""
    echo -e "${YELLOW}Gunakan -y untuk skip semua konfirmasi: termux-connecting -y${NC}"
    echo ""
    mkdir -p "$HOME/.config/termux-connecting"
    touch "$WELCOME_FILE"
fi

title "TERMUX CONNECTING v${VERSION} — Setup"

# ─── 1. coreutils ───
if ! command -v timeout >/dev/null; then
    echo "  Dibutuhkan: coreutils (untuk timeout)"
    if confirm "Install coreutils" "y"; then
        pkg install -y coreutils
    fi
fi

# ─── 2. Update & Upgrade ───
title "1. Update & Upgrade Paket"
if confirm "Jalankan pkg update && pkg upgrade" "y"; then
    echo "  Menjalankan pkg update && pkg upgrade..."
    if timeout 300 pkg update -y && timeout 300 pkg upgrade -y; then
        info "Update & upgrade berhasil"
    else
        warn "Gagal update/upgrade. Mungkin repo tidak stabil."
        echo ""
        echo "  Untuk mengganti ke repo stable, jalankan:"
        echo "  termux-change-repo"
        echo ""
        echo "  Pilih mirror yang stabil:"
        echo "  - SourceForge (SF) — paling stabil"
        echo "  - Grimler — recommended"
        echo "  - Albatross — alternatif"
        echo ""
        if confirm "Ganti repo sekarang" "n"; then
            termux-change-repo
            echo ""
            echo "  Ulangi: termux-connecting"
        fi
    fi
else
    warn "Lewati update/upgrade"
fi

# ─── 3. Git & Node.js ───
title "2. Cek Git & Node.js"
for cmd in git node; do
    if command -v "$cmd" >/dev/null; then
        info "$cmd sudah terinstall ($($cmd --version || echo '?'))"
    else
        echo "  $cmd belum terinstall."
        if confirm "Install $cmd" "y"; then
            pkg="$cmd"
            [ "$cmd" = "node" ] && pkg="nodejs-lts"
            pkg install -y "$pkg" && info "$cmd berhasil diinstall" || error "Gagal install $cmd"
        else
            warn "Lewati install $cmd"
        fi
    fi
done

# ─── 4. Password ───
title "3. Cek Password (passwd)"
if [ -f "$HOME/.termux_authinfo" ] || passwd -S | grep -q "P"; then
    info "Password sudah diatur"
else
    echo "  Belum ada password. Setting password diperlukan untuk SSH."
    if confirm "Set password sekarang" "y"; then
        echo ""
        echo "  Masukkan password baru:"
        if passwd; then
            info "Password berhasil disimpan"
        else
            error "Gagal menyimpan password"
        fi
    else
        warn "Lewati set password. SSH tidak akan bisa tanpa password."
    fi
fi

# ─── 5. SSH Server ───
title "4. Cek SSH Server (sshd)"
if pgrep -x sshd >/dev/null; then
    info "sshd sudah berjalan"
else
    echo "  sshd belum jalan. Menjalankan..."
    if sshd; then
        info "sshd berhasil dijalankan"
    else
        error "Gagal menjalankan sshd"
        echo "  Coba manual: sshd"
    fi
fi

# wake lock — cegah Termux dimatikan saat layar mati
if command -v termux-wake-lock >/dev/null; then
    termux-wake-lock 2>/dev/null && info "Wake lock aktif — koneksi tetap terjaga saat layar mati"
fi

# notification — agar Android tidak kill Termux (non-blocking)
if command -v termux-notification >/dev/null && timeout 2 termux-notification --help >/dev/null 2>&1; then
    termux-notification -t "Termux Connecting" -c "SSH server berjalan — port 8022" --id sshd-keepalive --ongoing >/dev/null 2>&1 &
fi

# battery optimization — buka setelan langsung
echo "  Buka setelan battery optimization:"
echo "  am start -a android.settings.IGNORE_BATTERY_OPTIMIZATION_SETTINGS"
echo "  Lalu cari Termux → pilih 'Tidak dioptimalkan'"
echo ""

# ─── 6. Informasi Koneksi ───
title "5. Informasi Koneksi"
USERNAME=$(whoami)

IP=""
if command -v ip >/dev/null; then
    IP=$(timeout 3 ip -4 addr show 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | grep -v 127.0.0.1 | head -1)
fi
if [ -z "$IP" ] && command -v ifconfig >/dev/null; then
    IP=$(timeout 3 ifconfig 2>/dev/null | awk '/inet /{print $2}' | grep -v 127.0.0.1 | head -1)
fi
if [ -z "$IP" ] && [ -d /data/data/com.termux ]; then
    IP=$(timeout 3 ip route get 1.1.1.1 2>/dev/null | awk '{print $7}' | head -1)
fi
if [ -z "$IP" ]; then
    IP=""
fi

is_cgnat() {
    [[ "$1" =~ ^10\. ]] || [[ "$1" =~ ^100\.(6[4-9]|[7-9][0-9]|1[0-1][0-9]|12[0-7])\. ]]
}

is_wifi() {
    [[ "$1" =~ ^192\.168\. ]] || [[ "$1" =~ ^172\.(1[6-9]|2[0-9]|3[01])\. ]]
}

echo "  Username : $USERNAME"
echo "  IP       : ${IP:-tidak terdeteksi}"
echo "  Port     : 8022"
echo ""

CONNECTION_OK=false

if [ -z "$IP" ]; then
    echo "  Pastikan HP terhubung ke WiFi, bukan data seluler."
    echo ""
    echo "  Langkah:"
    echo "  1. Buka Pengaturan → WiFi, hubungkan ke jaringan rumah/kantor"
    echo "  2. Setelah terhubung, jalankan ulang: termux-connecting -y"
elif is_cgnat "$IP"; then
    warn "IP ${IP} terdeteksi sebagai jaringan SELULER/VPN"
    echo "  PC dan HP harus dalam jaringan WiFi yang SAMA."
    echo ""
    echo "  Langkah:"
    echo "  1. Matikan data seluler dan VPN di HP"
    echo "  2. Buka Pengaturan → WiFi, hubungkan ke jaringan yang sama dengan PC"
    echo "  3. Catat IP yang muncul (biasanya 192.168.x.x)"
    echo "  4. Jalankan ulang: termux-connecting -y"
    echo "  5. Atau cek IP manual: ip a | grep wlan"
elif is_wifi "$IP"; then
    CONNECTION_OK=true
    echo "  Di PC/Mac:"
    echo "  npm i -g termux-connecting && termux-connect-pc"
    echo ""
    warn "Pastikan HP dan PC terhubung ke jaringan WiFi YANG SAMA"
    echo ""
    echo "  Data koneksi — simpan untuk setup PC:"
    echo "  ┌──────────────────────────────────┐"
    printf "  │ %-32s │\n" "Username : $USERNAME"
    printf "  │ %-32s │\n" "IP       : $IP"
    printf "  │ %-32s │\n" "Port     : 8022"
    echo "  └──────────────────────────────────┘"
else
    warn "IP ${IP} tidak dikenal — mungkin bukan jaringan lokal"
    echo "  Pastikan HP terhubung ke WiFi, bukan data seluler."
    echo ""
    echo "  Cek koneksi WiFi: ip a | grep wlan"
    echo "  Jika IP masih ${IP}, mungkin HP menggunakan VPN/proxy."
    echo "  Matikan VPN dan coba lagi: termux-connecting -y"
fi
echo ""

echo "----------------------------------------"
info "Setup selesai!"
echo ""

# ─── Menu setelah setup ───
if [ "$AUTO" = "false" ]; then
    while true; do
        echo ""
        echo "  1) Selesai"
        echo "  2) Matikan SSH server (sshd)"
        echo "  3) Status SSH server"
        echo "  4) Tampilkan ulang info koneksi"
        echo "  5) Cek permission & fitur"
        echo ""
        echo -n "  Pilih [1]: "
        read -r post_choice
        echo ""
        case "$post_choice" in
            2)
                if pgrep -x sshd >/dev/null; then
                    pkill sshd && info "sshd dimatikan"
                else
                    warn "sshd sedang tidak berjalan"
                fi
                ;;
            3)
                if pgrep -x sshd >/dev/null; then
                    info "sshd sedang berjalan (PID: $(pgrep -x sshd))"
                else
                    warn "sshd tidak berjalan. Jalankan: sshd"
                fi
                ;;
            4)
                echo "  Username : $USERNAME"
                echo "  IP       : ${IP:-tidak terdeteksi}"
                echo "  Port     : 8022"
                echo ""
                echo "  Di PC: termux-connect-pc connection"
                ;;
            5)
                # reuse permission check block
                HAS_STORAGE="no"; HAS_BOOT="no"; HAS_WAKE="no"
                [ -d "$HOME/storage" ] && HAS_STORAGE="yes"
                [ -f "$HOME/.termux/boot/boot-sshd" ] && HAS_BOOT="yes"
                command -v termux-wake-lock >/dev/null 2>&1 && HAS_WAKE="yes"
                title "Status Permission & Fitur"
                echo "  ┌─────────────────────────────────────────────┐"
                [ "$HAS_STORAGE" = "yes" ] && echo "  │  ✅  Storage      — akses penyimpanan  │" || echo "  │  ❌  Storage      — akses penyimpanan  │"
                [ "$HAS_BOOT" = "yes" ] && echo "  │  ✅  Termux:Boot  — auto-start sshd    │" || echo "  │  ❌  Termux:Boot  — auto-start sshd    │"
                [ "$HAS_WAKE" = "yes" ] && echo "  │  ✅  Wake lock    — koneksi tetap saat mati layar │" || echo "  │  ❌  Wake lock    — koneksi tetap saat mati layar │"
                echo "  └─────────────────────────────────────────────┘"
                echo ""
                if [ "$HAS_STORAGE" = "no" ] && confirm "  Setup storage permission" "y"; then termux-setup-storage; echo "  Izininkan pop-up permission di Android"; echo ""; fi
                if [ "$HAS_WAKE" = "no" ] && confirm "  Install wake lock (termux-api)" "y"; then pkg install -y termux-api; echo "  Install aplikasi Termux:API dari F-Droid:"; echo "  https://f-droid.org/packages/com.termux.api/"; echo ""; fi
                if [ "$HAS_BOOT" = "no" ] && confirm "  Setup auto-start sshd (Termux:Boot)" "y"; then mkdir -p "$HOME/.termux/boot"; echo 'sshd' > "$HOME/.termux/boot/boot-sshd"; chmod +x "$HOME/.termux/boot/boot-sshd"; info "Boot script: ~/.termux/boot/boot-sshd"; echo "  https://f-droid.org/packages/com.termux.boot/"; echo "  Reboot HP agar sshd jalan otomatis"; echo ""; fi
                [ "$HAS_WAKE" = "yes" ] && termux-wake-lock 2>/dev/null && info "Wake lock aktif"
                ;;
            *) break ;;
        esac
    done
    echo ""
    info "Sampai jumpa!"
fi
